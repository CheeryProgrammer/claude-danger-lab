# ── claude-danger-lab environment configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── SSH access ────────────────────────────────────────────────────────────────
# Your SSH public key (content of ~/.ssh/id_ed25519.pub or similar).
# The container will reject all connections until this is set.
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-email@example.com

# Host port mapped to container SSH (default: 2222)
SSH_PORT=2222

# ── Claude authentication ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# If left blank, run `claude login` inside the tmux session instead.
ANTHROPIC_API_KEY=sk-ant-...

# ── Remote Control eligibility (claude.ai subscription only) ──────────────────
# `claude remote-control` requires a claude.ai subscription login (NOT an API
# key) and reads your organization from ~/.claude.json's oauthAccount cache.
# That cache lives outside the persisted volume, so on a fresh container it is
# missing and remote-control fails with:
#   "Unable to determine your organization for Remote Control eligibility."
# Setting these three vars seeds the cache deterministically on every cold start.
# Find the values after logging in once (`claude login`), then on the HOST:
#   claude auth status --json        → email (USER_EMAIL), orgId (ORGANIZATION_UUID)
#   jq .oauthAccount.accountUuid ~/.claude.json   → ACCOUNT_UUID
# Leave blank if you only use ANTHROPIC_API_KEY (remote-control is unavailable then).
CLAUDE_CODE_ACCOUNT_UUID=
CLAUDE_CODE_USER_EMAIL=
CLAUDE_CODE_ORGANIZATION_UUID=

# ── GitHub authentication ─────────────────────────────────────────────────────
# Personal Access Token with repo + workflow scopes.
# Create at https://github.com/settings/tokens
# Enables: git push/pull over HTTPS and all gh CLI commands.
GITHUB_TOKEN=ghp_...

# ── Workspace (optional) ──────────────────────────────────────────────────────
# Leave unset → workspace lives in a Docker named volume (recommended).
# Set to a host path → that directory is bind-mounted as /workspace.
#   WORKSPACE_PATH=/home/you/projects
#   WORKSPACE_PATH=./mycode
# WORKSPACE_PATH=

# ── Dangerous mode ───────────────────────────────────────────────────────────
# Set to true to skip all permission prompts (--dangerously-skip-permissions).
# Claude will read, write, and execute without asking. Use with caution.
DANGEROUS_MODE=false

# ── Resource limits ───────────────────────────────────────────────────────────
MEMORY_LIMIT=4g
