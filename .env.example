# ── claude-danger-lab environment configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── SSH access ────────────────────────────────────────────────────────────────
# Your SSH public key (content of ~/.ssh/id_ed25519.pub or similar).
# The container will reject all connections until this is set.
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-email@example.com

# Host port mapped to container SSH (default: 2222)
SSH_PORT=2222

# ── Claude authentication ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# If left blank, run `claude login` inside the tmux session instead.
ANTHROPIC_API_KEY=sk-ant-...

# ── Workspace ─────────────────────────────────────────────────────────────────
# Host path that will be mounted to /workspace inside the container.
# Defaults to ./workspace (a subdirectory next to docker-compose.yml).
# Use an absolute path to mount an existing project directory.
WORKSPACE_PATH=./workspace

# ── Resource limits ───────────────────────────────────────────────────────────
MEMORY_LIMIT=4g
